<view class="container">
  <view wx:if="{{loading}}" class="text-muted" style="text-align:center;padding:40rpx;">加载中...</view>

  <view wx:elif="{{matches.length === 0}}" class="card text-muted" style="text-align:center;">
    暂无比赛
  </view>

  <view wx:else>
    <view wx:for="{{matches}}" wx:key="id" class="card" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="flex-row" style="justify-content:space-between;">
        <text style="font-weight:600;">{{item.location}}</text>
        <text class="text-muted" style="font-size:24rpx;">{{item.status}}</text>
      </view>
      <text class="text-muted" style="font-size:26rpx;">{{item.date}}</text>
    </view>
  </view>
</view>
