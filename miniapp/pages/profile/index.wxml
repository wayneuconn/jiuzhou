<view class="container">
  <view wx:if="{{loading}}" class="text-muted">加载中...</view>

  <block wx:elif="{{user}}">
    <view class="card flex-row" style="gap:24rpx;">
      <image wx:if="{{user.avatar}}" src="{{user.avatar}}" style="width:120rpx;height:120rpx;border-radius:50%;" />
      <view wx:else class="avatar-placeholder">{{user.displayName}}</view>
      <view class="flex-col">
        <text style="font-size:36rpx;font-weight:600;">{{user.displayName}}</text>
        <text class="text-muted" style="font-size:26rpx;">{{user.role}}</text>
      </view>
    </view>

    <view class="card">
      <view class="flex-row" style="justify-content:space-between;padding:12rpx 0;">
        <text>出勤</text><text>{{user.attendanceCount}}</text>
      </view>
      <view class="flex-row" style="justify-content:space-between;padding:12rpx 0;">
        <text>迟到</text><text>{{user.lateCount}}</text>
      </view>
      <view class="flex-row" style="justify-content:space-between;padding:12rpx 0;">
        <text>危险动作</text><text>{{user.dangerousCount}}</text>
      </view>
    </view>

    <button wx:if="{{user.role === 'admin'}}" class="btn-primary" bindtap="goAdmin" style="margin-top:24rpx;">管理后台</button>
    <button class="btn-primary" bindtap="logout" style="margin-top:16rpx;background:#999;">退出登录</button>
  </block>
</view>
