<view class="container">
  <view style="padding:48rpx 0 32rpx;text-align:center;">
    <view style="font-size:44rpx;font-weight:700;">完善资料</view>
    <view class="text-muted" style="margin-top:12rpx;font-size:28rpx;">让队友认识你</view>
  </view>

  <view class="card">
    <view class="field-label">昵称</view>
    <input
      class="field-input"
      placeholder="输入你在队里的名字"
      placeholder-style="color:#bbb"
      value="{{displayName}}"
      bindinput="onNameInput"
      maxlength="20" />
  </view>

  <view class="card" style="margin-top:16rpx;">
    <view class="field-label">擅长位置</view>
    <view class="position-row">
      <view
        wx:for="{{POSITIONS}}"
        wx:key="*this"
        class="position-chip {{selectedMap[item] ? 'selected' : ''}}"
        bindtap="togglePosition"
        data-pos="{{item}}">
        {{item}}
      </view>
    </view>
  </view>

  <button
    class="btn-primary"
    style="margin-top:32rpx;"
    bindtap="onSubmit"
    loading="{{loading}}"
    disabled="{{loading || !displayName}}">
    完成，进入球队
  </button>
</view>
