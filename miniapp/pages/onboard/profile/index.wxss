.field-label {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 16rpx;
}

.field-input {
  font-size: 32rpx;
  color: #1f1f1f;
  padding: 12rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
  width: 100%;
}

.position-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 8rpx;
}

.position-chip {
  padding: 14rpx 32rpx;
  border-radius: 999rpx;
  background: #f5f5f5;
  font-size: 28rpx;
  color: #555;
  border: 2rpx solid transparent;
}

.position-chip.selected {
  background: #e8f0fe;
  color: #1a73e8;
  border-color: #1a73e8;
  font-weight: 600;
}
