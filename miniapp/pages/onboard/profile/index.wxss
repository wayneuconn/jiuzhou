.input {
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 30rpx;
}

.position-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.position-chip {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  background: #f0f0f0;
  font-size: 28rpx;
}

.position-chip.selected {
  background: #1a73e8;
  color: #ffffff;
}
