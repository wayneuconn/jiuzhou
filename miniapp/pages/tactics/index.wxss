.pitch {
  background: #2e7d32;
  border-radius: 16rpx;
  position: relative;
}

.player-token {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #1f1f1f;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.3);
}
