rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isMatchCaptain(matchId) {
      let m = get(/databases/$(database)/documents/matches/$(matchId)).data;
      return isAuth() && (m.captainA == request.auth.uid || m.captainB == request.auth.uid);
    }

    // Users: any authed user can read; self can update profile; admin can update role/membership
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) &&
                        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'membershipType'])
                    || isAdmin();
    }

    // Matches: any authed user can read; admin can write
    match /matches/{matchId} {
      allow read: if isAuth();
      allow write: if isAdmin();

      // Registrations subcollection
      match /registrations/{regId} {
        allow read: if isAuth();
        // Any authed user can register themselves while the match is open
        allow create: if isAuth() && request.auth.uid == regId &&
          (get(/databases/$(database)/documents/matches/$(matchId)).data.status == 'registration_r1' ||
           get(/databases/$(database)/documents/matches/$(matchId)).data.status == 'registration_r2');
        // Self can withdraw; admin can do anything; captains can only update the `team` field
        allow update: if isOwner(regId)
          || isAdmin()
          || (isMatchCaptain(matchId) &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['team']));
        allow delete: if isAdmin();
      }

      // Per-team and general board formations
      match /formations/{formationId} {
        allow read: if isAuth() && (
          isAdmin() ||
          formationId == 'board' ||
          (formationId == 'teamA' && (
            get(/databases/$(database)/documents/matches/$(matchId)).data.captainA == request.auth.uid ||
            (exists(/databases/$(database)/documents/matches/$(matchId)/registrations/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/matches/$(matchId)/registrations/$(request.auth.uid)).data.team == 'A')
          )) ||
          (formationId == 'teamB' && (
            get(/databases/$(database)/documents/matches/$(matchId)).data.captainB == request.auth.uid ||
            (exists(/databases/$(database)/documents/matches/$(matchId)/registrations/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/matches/$(matchId)/registrations/$(request.auth.uid)).data.team == 'B')
          ))
        );
        allow write: if isAdmin()
          || (formationId == 'board'  && (isAdmin() || isMatchCaptain(matchId)))
          || (formationId == 'teamA'  &&
              get(/databases/$(database)/documents/matches/$(matchId)).data.captainA == request.auth.uid)
          || (formationId == 'teamB'  &&
              get(/databases/$(database)/documents/matches/$(matchId)).data.captainB == request.auth.uid);
      }
    }

    // Finances: admin only
    match /finances/{docId} {
      allow read, write: if isAdmin();
    }

    // Announcements: any authed user can read; admin can write
    match /announcements/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Config: any authed user can read; admin can write
    match /config/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Global tactics board (legacy / fallback when no active match)
    match /tactics/{docId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // Payment events
    match /paymentEvents/{eventId} {
      allow read: if isAuth();
      allow write: if isAdmin();

      match /payments/{uid} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid) && request.resource.data.status == 'pending';
        allow update: if isAdmin()
                      || (isOwner(uid) && request.resource.data.status == 'pending');
      }
    }

    // Invite tokens
    match /inviteTokens/{tokenId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
